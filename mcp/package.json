{
  "name": "medical-mcp",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "medical-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"if (process.platform !== 'win32') require('fs').chmodSync('build/index.js', 0o755)\"",
    "start": "node build/index.js",
    "start:http": "node build/index.js --http",
    "start:http:port": "node build/index.js --http --port=3000",
    "dev": "npm run build && npm run start",
    "dev:http": "npm run build && npm run start:http",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "files": [
    "build",
    "scripts"
  ],
  "main": "index.js",
  "keywords": [
    "medical",
    "healthcare",
    "drugs",
    "fda",
    "who",
    "pubmed",
    "mcp"
  ],
  "author": "mochiyaki",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mochiyaki/dentist.git"
  },
  "homepage": "https://github.com/mochiyaki/dentist",
  "description": "Model Context Protocol (MCP) server that provides comprehensive medical information by querying multiple authoritative medical APIs",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "puppeteer": "^24.12.1",
    "redis": "^4.7.0",
    "superagent": "^10.2.2",
    "zod": "^3.25.75"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^24.0.10",
    "@types/superagent": "^8.1.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.8.3"
  }
}
